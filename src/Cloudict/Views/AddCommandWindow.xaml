<local:GlassWindow x:Class="Cloudict.AddCommandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AddCmd_Title}" Height="750" Width="900"
        WindowStartupLocation="CenterOwner"
        FlowDirection="{DynamicResource AppFlowDirection}"
        Foreground="#F1F3F8"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        FontFamily="{DynamicResource AppFontFamily}"
        xmlns:local="clr-namespace:Cloudict">


    <Border Background="#2D2D2D" Margin="30" CornerRadius="15">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{DynamicResource AddCmd_Header}" Grid.ColumnSpan="2" FontSize="30" FontWeight="Bold" Margin="0,0,0,25"/>

            <TextBlock Text="{DynamicResource AddCmd_PhraseLabel}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Foreground="#CCCCCC" FontSize="20"/>
            <TextBox x:Name="txtCommandPhrase" Grid.Row="1" Grid.Column="1" Margin="5" Style="{StaticResource ModernTextBoxStyle}" FontSize="20" ToolTip="{DynamicResource AddCmd_PhraseTooltip}"/>

            <TextBlock Text="{DynamicResource AddCmd_ActionTypeLabel}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,20,0,0" Foreground="#CCCCCC" FontSize="20"/>
            <ComboBox x:Name="cmbActionType" Grid.Row="2" Grid.Column="1" Margin="5,20,5,0" Style="{StaticResource ModernComboBoxStyle}" FontSize="20">
                <ComboBoxItem Content="{DynamicResource Common_TypeText}"/>
                <ComboBoxItem Content="{DynamicResource Common_SendKey}"/>
                
                <ComboBoxItem Content="{DynamicResource Common_ChangeToPersian}"/>
                <ComboBoxItem Content="{DynamicResource Common_ChangeToEnglish}"/>
                <ComboBoxItem Content="{DynamicResource Common_DeleteLastWords}"/>
            </ComboBox>
            <TextBlock Text="{DynamicResource AddCmd_ActionValueLabel}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,20,0,0" Foreground="#CCCCCC" FontSize="20"/>
            <Grid Grid.Row="3" Grid.Column="1" Margin="5,20,5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBox x:Name="txtActionValue" 
                         Grid.Row="0"
                         Style="{StaticResource ModernTextBoxStyle}" 
                         FontSize="20" />
                
                <!-- دکمه‌های کلیدهای رایج -->
                <StackPanel x:Name="pnlCommonKeys" 
                            Grid.Row="1" 
                            Orientation="Horizontal" 
                            Margin="0,5,0,0" 
                            Visibility="Collapsed">
                    <Button Content="Enter" 
                                     Width="60" 
                                     Height="25" 
                                     Margin="2" 
                                     Click="CommonKey_Click" 
                                     Tag="ENTER" 
                                     Style="{StaticResource SecondaryButtonStyle}" />
                     <Button Content="Tab" 
                              Width="50" 
                              Height="25" 
                              Margin="2" 
                              Click="CommonKey_Click" 
                              Tag="TAB" 
                              Style="{StaticResource SecondaryButtonStyle}" />
                      <Button Content="Escape" 
                              Width="60" 
                              Height="25" 
                              Margin="2" 
                              Click="CommonKey_Click" 
                              Tag="ESC" 
                              Style="{StaticResource SecondaryButtonStyle}" />
                      <Button Content="Space" 
                              Width="60" 
                              Height="25" 
                              Margin="2" 
                              Click="CommonKey_Click" 
                              Tag=" " 
                              Style="{StaticResource SecondaryButtonStyle}" />
                      <Button Content="Backspace" 
                              Width="80" 
                              Height="25" 
                              Margin="2" 
                              Click="CommonKey_Click" 
                              Tag="BACKSPACE" 
                              Style="{StaticResource SecondaryButtonStyle}" />
                      <Button Content="Delete" 
                              Width="60" 
                              Height="25" 
                              Margin="2" 
                              Click="CommonKey_Click" 
                              Tag="DELETE" 
                              Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
                
                <!-- ردیف دوم دکمه‌ها -->
                <StackPanel x:Name="pnlCommonKeys2" 
                            Grid.Row="1" 
                            Orientation="Horizontal" 
                            Margin="0,30,0,0" 
                            Visibility="Collapsed">
                    <Button Content="Ctrl+C" 
                            Width="60" 
                            Height="25" 
                            Margin="2" 
                            Click="CommonKey_Click" 
                            Tag="^c" 
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="Ctrl+V" 
                            Width="60" 
                            Height="25" 
                            Margin="2" 
                            Click="CommonKey_Click" 
                            Tag="^v" 
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="Ctrl+A" 
                            Width="60" 
                            Height="25" 
                            Margin="2" 
                            Click="CommonKey_Click" 
                            Tag="^a" 
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="Ctrl+Z" 
                            Width="60" 
                            Height="25" 
                            Margin="2" 
                            Click="CommonKey_Click" 
                            Tag="^z" 
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="F5" 
                            Width="40" 
                            Height="25" 
                            Margin="2" 
                            Click="CommonKey_Click" 
                            Tag="F5" 
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="Alt+Tab" 
                            Width="70" 
                            Height="25" 
                            Margin="2" 
                            Click="CommonKey_Click" 
                            Tag="%{TAB}" 
                            Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="4" Grid.ColumnSpan="2" Margin="0,20,0,20" VerticalScrollBarVisibility="Auto" Height="300">
                <TextBlock x:Name="txtHelpText" TextWrapping="Wrap" Foreground="#CCCCCC" FontSize="18" LineHeight="28" Text="{DynamicResource AddCmd_HelpText}"/>
            </ScrollViewer>

            <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="{DynamicResource Common_Discard}" Width="140" Margin="10" FontSize="20" Click="btnCancel_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                <Button x:Name="btnSave" Content="{DynamicResource Common_Save}" Width="140" Margin="10" FontSize="20" Click="btnSave_Click" Style="{StaticResource RoundedButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</local:GlassWindow>