<local:GlassWindow x:Class="Cloudict.KeySelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource KeySel_Title}" Height="320" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="{DynamicResource AppFlowDirection}"
        Foreground="#F1F3F8"
        FontFamily="{DynamicResource AppFontFamily}"
        FontSize="14"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        KeyDown="Window_KeyDown"
        Focusable="True"
        KeyboardNavigation.TabNavigation="None"
        xmlns:local="clr-namespace:Cloudict">
    
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Label Grid.Row="0" Content="{DynamicResource KeySel_Prompt}" 
               Style="{StaticResource DarkLabelStyle}" 
               FontSize="16" 
               FontWeight="Bold" 
               HorizontalAlignment="Center"/>
        
        <TextBox Grid.Row="2" x:Name="txtSelectedKeys" 
                 Style="{StaticResource DarkTextBoxStyle}" 
                 Height="40" 
                 FontSize="14" 
                 IsReadOnly="True" 
                 VerticalContentAlignment="Center"
                 HorizontalAlignment="Stretch"
                 PreviewMouseDown="txtSelectedKeys_PreviewMouseDown"
                 Focusable="False"/>
        
        <TextBlock Grid.Row="4" 
                   Text="{DynamicResource KeySel_Help}"
                   Foreground="#FFCCCCCC"
                   FontSize="12"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top"/>
        
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnClear" Content="{DynamicResource Common_Clear}" 
                    Style="{StaticResource CancelButtonStyle}" 
                    Width="80" 
                    Height="35" 
                    Margin="0,0,10,0"
                    Click="btnClear_Click"/>
            <Button x:Name="btnOK" Content="{DynamicResource Common_Confirm}" 
                    Style="{StaticResource SaveButtonStyle}" 
                    Width="80" 
                    Height="35" 
                    Margin="0,0,10,0"
                    Click="btnOK_Click"
                    IsDefault="False"/>
            <Button x:Name="btnCancel" Content="{DynamicResource Common_Cancel}" 
                    Style="{StaticResource CancelButtonStyle}" 
                    Width="80" 
                    Height="35"
                    Click="btnCancel_Click"
                    IsCancel="False"/>
        </StackPanel>
    </Grid>
</local:GlassWindow>